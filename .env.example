# Express port (default 3001). Vite’s dev proxy reads this; `npm run dev` also waits for /api/health on this port before starting Vite.
# PORT=3001

# If the API runs on a different origin than PORT implies, set the full URL for the Vite proxy:
# VITE_API_PROXY_TARGET=http://127.0.0.1:3002

# MiniMax API Key - get one at https://platform.minimax.io/user-center/basic-information/interface-key
MINIMAX_API_KEY=your_api_key_here

# Admin secret - required for /admin page (delete participants, set match scores)
ADMIN_SECRET=your_admin_secret_here

# Supabase (optional) — persist data in Postgres instead of server/*.json
# See docs/SUPABASE_SOP.md — use Secret key (sb_secret_...) or legacy service_role; never in the browser.
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_...   # or legacy JWT service_role key
